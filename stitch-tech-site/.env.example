# --- Database (local SQLite by default) ---
# Prisma + better-sqlite3. On Vercel/serverless, file DB is often unusable; contact API
# still sends email if SMTP is configured. For durable leads in production, use Turso/Neon/etc.
# DATABASE_URL="file:./prisma/dev.db"

# --- Email (contact form + newsletter notifications) ---
# If RESEND_API_KEY is set, mail is sent via Resend (takes precedence over SMTP below).
# RESEND_FROM must use an address/domain verified in Resend (e.g. noreply@yourdomain).
# Set these in Vercel/host env for production.
# RESEND_API_KEY=re_47NLjwqK_FtP2Ke1spJxnewYkS6XF8Hpn
# RESEND_FROM="Caudate Tech <noreply@caudate-tech.com>"
#
# Without Resend and without EMAIL_USER + EMAIL_PASS, outbound mail is mocked (console only).
# In production you can use SMTP (Gmail app password, etc.) when Resend is not configured.
#
# EMAIL_USER=
# EMAIL_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Optional; defaults to "Caudate Tech" <contact@caudate-tech.com>
# EMAIL_FROM=

# --- WhatsApp click-to-chat ---
# Optional: override number (digits only, no +). Default in code is 12016321255.
# NEXT_PUBLIC_WHATSAPP_NUMBER=12016321255
